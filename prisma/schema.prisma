datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model Convite {
  id               String      @id @default(uuid())
  codigo           String      @unique
  nomeExibicao     String
  maxAcompanhantes Int         @default(0)
  confirmado       Boolean     @default(false)
  qtdConfirmados   Int         @default(0)
  dataConfirmacao  DateTime?
  isAdmin          Boolean     @default(false)
  mensagens        Mensagem[]
}

model Mensagem {
  id         String   @id @default(uuid())
  conteudo   String   @db.Text
  createdAt  DateTime @default(now())
  conviteId  String
  convite    Convite  @relation(fields: [conviteId], references: [id], onDelete: Cascade)
}

model MensagemMural {
  id        String   @id @default(uuid())
  nome      String
  mensagem  String   @db.Text
  createdAt DateTime @default(now())
  
  // Controle de segurança (Soft delete ou aprovação)
  aprovada  Boolean  @default(true) 

  @@index([createdAt(sort: Desc)])
}

// ─── ESTRUTURA DO RSVP (CONFIRMAÇÃO DE PRESENÇA) ───

model Familia {
  id                 String      @id @default(uuid())
  nomeExibicao       String      // Ex: "Dona Lucinha e Família"
  codigoAcesso       String      @unique // Ex: "LUCINHA2026"
  
  // Onde vamos guardar o número final
  numeroConfirmados  Int?        // Se for null, é porque ainda não responderam
  
  convidados         Convidado[] 
}

model Convidado {
  id          String   @id @default(uuid())
  nome        String
  
  confirmado  Boolean  @default(false)
  
  familiaId   String
  familia     Familia  @relation(fields: [familiaId], references: [id], onDelete: Cascade)
}

// ─── ESTRUTURA DOS PRESENTES ───
model Presente {
  id            String    @id @default(uuid())
  nome          String
  imagemUrl     String
  valor         Float
  linkCredito   String?
  linkPix       String?
  comprado      Boolean   @default(false)
  
  // ─── NOVOS CAMPOS PARA CONTROLE DOS NOIVOS ───
  compradorNome String?
  mensagem      String?
  compradoEm    DateTime?
}